# --- Configuración del servidor PBI ---

# Puerto donde escucha el backend
PORT=4000

# Origen permitido del frontend (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Secreto para firmar las cookies de sesión del panel
SESSION_SECRET=cambia-esto-por-un-valor-aleatorio-largo

# --- Conexión a Proxmox Backup Server ---
# Los hosts PBS se configuran normalmente desde la propia interfaz
# (Configuración → Añadir host), que los guarda de forma persistente.
# Estas variables solo se usan como valores por defecto.

# Host y puerto del PBS (sin barra final). Ej: https://192.168.1.10:8007
PBS_HOST=https://localhost:8007

# Nombre del nodo PBS (normalmente "localhost")
PBS_NODE=localhost

# Verificar el certificado TLS del PBS. En PBS suele ser autofirmado -> false
PBS_VERIFY_TLS=false
