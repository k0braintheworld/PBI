#!/bin/sh
set -e

# Limpiar binarios y el disparador de actualización siempre que se elimina
if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
  systemctl disable --now pbi-update.path >/dev/null 2>&1 || true
  rm -rf /opt/pbi
  rm -f /etc/sudoers.d/pbi
fi

# En purge, eliminar tambien datos, configuracion y usuario
if [ "$1" = "purge" ]; then
  rm -rf /var/lib/pbi /etc/pbi
  deluser --system pbi >/dev/null 2>&1 || true
fi

systemctl daemon-reload >/dev/null 2>&1 || true

exit 0
