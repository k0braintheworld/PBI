PORT=8800
PBI_DATA_DIR=/var/lib/pbi
PBI_WEB_DIR=/opt/pbi/web/dist
NODE_ENV=production
SESSION_SECRET=CHANGE_ME

# HTTPS: certificado autofirmado generado al instalar. Sustituye estos ficheros
# por tu propio certificado si quieres uno de confianza. Deja las rutas vacías
# para servir en HTTP plano.
PBI_TLS_CERT=/var/lib/pbi/tls/pbi.crt
PBI_TLS_KEY=/var/lib/pbi/tls/pbi.key
