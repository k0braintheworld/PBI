#!/bin/sh
# Actualizador de PBI (se ejecuta como root vía una regla sudoers acotada).
# Descarga el .deb de una release OFICIAL, verifica su SHA-256 y lo instala en
# una unidad systemd transitoria, desacoplada de pbi.service (que se reiniciará).
#
# Uso:  pbi-update <url-del-.deb> <sha256>
set -eu

URL="${1:-}"
SHA="${2:-}"

# Solo releases oficiales de PBI
case "$URL" in
  https://github.com/k0braintheworld/PBI/releases/download/*.deb) : ;;
  *) echo "URL no permitida" >&2; exit 2 ;;
esac
# SHA-256 con formato válido
echo "$SHA" | grep -Eq '^[a-fA-F0-9]{64}$' || { echo "Checksum no valido" >&2; exit 2; }

DEB=/var/lib/pbi/.pending-update.deb
rm -f "$DEB"

command -v curl >/dev/null 2>&1 || { echo "curl no esta instalado" >&2; exit 5; }
curl -fsSL --max-time 180 "$URL" -o "$DEB" || { echo "Descarga fallida" >&2; exit 3; }

if ! echo "${SHA}  ${DEB}" | sha256sum -c - >/dev/null 2>&1; then
  rm -f "$DEB"
  echo "El checksum no coincide: descarga descartada" >&2
  exit 4
fi

command -v systemd-run >/dev/null 2>&1 || { echo "systemd-run no disponible" >&2; exit 6; }
# Instala en segundo plano, fuera del cgroup de pbi.service (que el propio dpkg reiniciará)
systemd-run --collect --unit=pbi-self-update --description="PBI self-update" \
  /bin/sh -c 'sleep 1; dpkg -i /var/lib/pbi/.pending-update.deb >/var/lib/pbi/.update.log 2>&1; rm -f /var/lib/pbi/.pending-update.deb' \
  >/dev/null 2>&1

echo "OK"
exit 0
