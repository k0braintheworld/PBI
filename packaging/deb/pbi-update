#!/bin/sh
# Actualizador de PBI. Lo dispara (como ROOT) la unidad pbi-update.path cuando el
# servicio web deja una solicitud en /var/lib/pbi/.update-request:
#   linea 1 = URL del .deb (release oficial)   linea 2 = SHA-256 esperado
# Descarga, verifica el checksum e instala. El servicio web NUNCA escala
# privilegios: solo escribe la solicitud.
set -eu

REQ=/var/lib/pbi/.update-request
LOG=/var/lib/pbi/.update.log
DEB=/var/lib/pbi/.pending-update.deb

[ -f "$REQ" ] || exit 0
URL=$(sed -n '1p' "$REQ" 2>/dev/null || true)
SHA=$(sed -n '2p' "$REQ" 2>/dev/null || true)
rm -f "$REQ"   # consumir la solicitud (evita reprocesos)

{
  echo "== $(date) =="

  # Solo releases oficiales de PBI
  case "$URL" in
    https://github.com/k0braintheworld/PBI/releases/download/*.deb) : ;;
    *) echo "URL no permitida: $URL"; exit 2 ;;
  esac
  echo "$SHA" | grep -Eq '^[a-fA-F0-9]{64}$' || { echo "Checksum con formato no valido"; exit 2; }

  rm -f "$DEB"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL --max-time 300 "$URL" -o "$DEB" || { echo "Descarga fallida (curl)"; exit 3; }
  elif command -v wget >/dev/null 2>&1; then
    wget -q -T 300 -O "$DEB" "$URL" || { echo "Descarga fallida (wget)"; exit 3; }
  else
    echo "Ni curl ni wget estan disponibles"; exit 5
  fi

  if ! echo "${SHA}  ${DEB}" | sha256sum -c - >/dev/null 2>&1; then
    rm -f "$DEB"; echo "El checksum NO coincide: descarga descartada"; exit 4
  fi

  echo "Checksum OK. Instalando..."
  dpkg -i "$DEB"          # su postinst reiniciara pbi.service (unidad distinta a esta)
  rm -f "$DEB"
  echo "Instalacion completada."
} >>"$LOG" 2>&1
